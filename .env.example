# Pooled Neon connection for application traffic.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require"

# Direct Neon connection for Prisma migrations and seed operations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require"

# Use a long random value in every deployed environment.
JWT_SECRET="replace-with-at-least-32-random-characters"

# Optional. Defaults to 7d.
JWT_EXPIRES_IN="7d"
